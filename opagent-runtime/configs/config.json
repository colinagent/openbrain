{
  "baseDir": "~/.openbrain",
  "env": "local",
  "override": true,
  "objectStore": {
    "type": "fs",
    "fs": {
      "baseDir": "objects"
    }
  },
  "heartbeat": {
    "interval": "30s"
  },
  "runtimeUpdate": {
    "enabled": true,
    "manifestURL": "https://download.op-agent.com/runtime/latest/manifest.json",
    "checkInterval": "30m",
    "checkTimeout": "8s",
    "idleGracePeriod": "15s",
    "downloadDir": "run/runtime-update"
  },
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  }
}
