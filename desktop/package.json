{
  "name": "openbrain",
  "productName": "OpenBrain",
  "version": "0.1.1",
  "author": "OpAgent Inc",
  "license": "AGPL-3.0",
  "description": "openbrain - Markdown editor with AI agent support",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:all": "bash ../scripts/openbrain/openbrain-run-dev.sh",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:icon:mac": "bash scripts/generate-app-icon.sh",
    "start": "electron .",
    "preview": "npm run build && electron .",
    "sync-settings": "bash scripts/sync-settings.sh",
    "dev-restart": "bash scripts/dev-restart.sh",
    "migrate:threads:markers": "node scripts/migrate-thread-markers.mjs",
    "check:locales": "node scripts/check-locale-parity.mjs",
    "test:i18n": "npm run build:main && node --test dist/main/i18n/locales.test.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "npm run build:icon:mac && npm run build && npm run build:runtime:mac && electron-builder --mac --arm64",
    "dist:win": "npm run build && npm run build:runtime:win && electron-builder --win --x64",
    "dist:linux": "npm run build && npm run build:runtime:linux && electron-builder --linux --x64",
    "build:runtime:mac": "bash scripts/build-runtime-bundle.sh darwin-arm64",
    "build:runtime:win": "bash scripts/build-runtime-bundle.sh windows-amd64",
    "build:runtime:linux": "bash scripts/build-runtime-bundle.sh linux-amd64"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.4",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.10.6",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "^6.5.8",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.35.3",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.3.2",
    "@xyflow/react": "^12.11.1",
    "beautiful-mermaid": "^1.0.2",
    "dagre": "^0.8.5",
    "electron-updater": "^6.3.9",
    "epubjs": "^0.3.93",
    "i18next": "^26.3.0",
    "jsonc-parser": "^3.3.1",
    "katex": "^0.16.27",
    "pdfjs-dist": "^6.0.227",
    "prismjs": "^1.30.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ssh2": "^1.17.0",
    "tar": "7.5.20",
    "unicode-animations": "^1.0.3",
    "ws": "8.21.1",
    "yaml": "^2.9.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/dagre": "^0.7.53",
    "@types/node": "^22.10.6",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
