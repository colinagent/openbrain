{
  // Configuration file schema version. Keep as 1 unless release notes say otherwise.
  "version": 1,

  // Keyboard shortcuts. Add new entries with a `key` chord and command id.
  // Platform-specific overrides (`mac`, `linux`, `win`) can replace `key` on that OS.
  "keybindings": [
    {
      // Open the settings UI/configuration directory.
      "key": "cmd+,",
      "command": "openbrain.openSettings"
    },
    {
      // Open the command palette.
      "key": "cmd+shift+p",
      "command": "openbrain.openCommandPalette"
    }
  ]
}
