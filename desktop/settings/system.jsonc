{
  // Configuration file schema version. Keep as 1 unless release notes say otherwise.
  "version": 1,

  // Runtime logging. Enable temporarily when diagnosing desktop issues.
  "logging": {
    "enabled": false,
    // Common values: "debug", "info", "warn", "error".
    "level": "info"
  },

  // Extra diagnostics collection/reporting switches.
  "diagnostics": {
    "enabled": false
  },

  // Power management while OpenBrain is running.
  "power": {
    // off | whileAgentRunning | whileAppRunning
    // Legacy: preventSleepWhileAgentRunning: true maps to whileAgentRunning on load.
    "idleSleepPolicy": "off"
  }
}
